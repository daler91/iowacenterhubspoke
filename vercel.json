{
  "installCommand": "cd frontend && yarn install",
  "buildCommand": "cd frontend && yarn build",
  "outputDirectory": "frontend/build",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://melodious-contentment-production-f2e0.up.railway.app/api/:path*"
    },
    {
      "source": "/((?!static|favicon|manifest|logo|robots).*)",
      "destination": "/index.html"
    }
  ]
}
