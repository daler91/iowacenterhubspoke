# ==============================================================================
# Iowa Center HubSpoke Scheduler - Environment Variables
# ==============================================================================
# Copy this file to backend/.env and fill in the values.
# Variables marked [REQUIRED] must be set. Others have sensible defaults.
# ==============================================================================

# --- Database ---
MONGO_URL=mongodb://localhost:27017          # [REQUIRED] MongoDB connection string
DB_NAME=iowa_center_hub                      # Database name (default: iowa_center_hub)
# MONGO_MAX_POOL_SIZE=50                     # Motor connection-pool cap
# MONGO_MIN_POOL_SIZE=5                      # Motor connection-pool floor
# MONGO_SELECTION_TIMEOUT_MS=5000            # Fail-fast timeout for server selection

# --- Authentication ---
JWT_SECRET=change-me-to-a-random-secret      # [REQUIRED] Secret key for JWT token signing
# JWT_LIFETIME_SECONDS=14400                 # Access-token lifetime (default 4h)
# JWT_REFRESH_LIFETIME_SECONDS=2592000       # Refresh-token lifetime (default 30d)
# BCRYPT_ROUNDS=14                           # bcrypt cost factor (default 14 — OWASP recommended)
# LOGIN_LOCKOUT_THRESHOLD=10                 # Failed logins per email before temporary lockout
# LOGIN_LOCKOUT_WINDOW_MINUTES=15            # Lockout window
# INVITATION_EXPIRY_DAYS=14                  # How long invitation links stay valid
# PASSWORD_RESET_EXPIRY_HOURS=24             # How long /forgot-password tokens stay valid
# PORTAL_TOKEN_EXPIRY_DAYS=3                 # How long partner-portal magic links stay valid
# TOKEN_ENCRYPTION_KEY=                      # [REQUIRED in production] Fernet key for OAuth token at-rest
                                             #   encryption. Generate with:
                                             #   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ADMIN_EMAIL=                                 # Email to auto-promote to admin on startup (optional)

# --- Scheduling behaviour ---
# SCHEDULE_TIMEZONE=America/Chicago          # Wall-clock tz used for DST-nonexistent-time validation
# ACTIVITY_LOG_RETENTION_DAYS=90             # TTL for activity_logs entries

# --- Redis (used for background jobs & rate limiting) ---
REDIS_URL=redis://localhost:6379             # Redis connection string

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173  # Comma-separated allowed origins (prod: https://theiowacenter-hub.org,https://www.theiowacenter-hub.org)

# --- Email (SMTP via Resend) ---
# Resend (resend.com) is the recommended provider: free tier 100 emails/day,
# 3,000/month. Any other SMTP provider works — only the four SMTP_* values change.
# Leave SMTP_HOST empty in dev to log emails instead of sending them.
EMAIL_FROM=noreply@example.com               # REPLACE ME — sender address on a domain verified in Resend
SMTP_HOST=smtp.resend.com                    # Resend SMTP relay (leave empty to disable email in dev)
SMTP_PORT=587                                # STARTTLS port
SMTP_USER=resend                             # Literal string "resend" for all Resend SMTP accounts
SMTP_PASSWORD=                               # Resend API key (starts with re_), created in Resend dashboard
APP_URL=                                     # Public base URL for magic links (e.g. https://theiowacenter-hub.org)

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=                         # Google Maps API key for drive time calculation & map view
VITE_GOOGLE_MAPS_API_KEY=                    # Same key, exposed to frontend via Vite

# --- Frontend ---
VITE_BACKEND_URL=                            # Backend API URL (leave empty if same-origin)

# --- Outlook Integration (optional) ---
AZURE_TENANT_ID=                             # Azure AD tenant ID for Outlook sync
AZURE_CLIENT_ID=                             # Azure AD app client ID
AZURE_CLIENT_SECRET=                         # Azure AD app client secret

# --- Outlook Calendar - OAuth 2.0 (optional, for individual Microsoft accounts) ---
OUTLOOK_OAUTH_CLIENT_ID=                     # Microsoft OAuth app client ID (from Azure portal)
OUTLOOK_OAUTH_CLIENT_SECRET=                 # Microsoft OAuth app client secret
OUTLOOK_OAUTH_REDIRECT_URI=                  # e.g. https://theiowacenter-hub.org/api/v1/outlook/callback

# --- Google Calendar - Service Account (optional, for Google Workspace) ---
GOOGLE_SERVICE_ACCOUNT_FILE=                 # Path to Google service account JSON key file
GOOGLE_SA_CLIENT_EMAIL=                      # Alternative: service account email
GOOGLE_SA_PRIVATE_KEY=                       # Alternative: service account private key (PEM)
GOOGLE_SA_PROJECT_ID=                        # Alternative: GCP project ID

# --- Google Calendar - OAuth 2.0 (optional, for regular Gmail accounts) ---
GOOGLE_OAUTH_CLIENT_ID=                      # Google OAuth client ID (from Cloud Console)
GOOGLE_OAUTH_CLIENT_SECRET=                  # Google OAuth client secret
GOOGLE_OAUTH_REDIRECT_URI=                   # e.g. https://theiowacenter-hub.org/api/v1/google/callback

# --- Environment ---
ENVIRONMENT=development                      # Set to "production" for production deployments

# --- Sentry (optional) ---
SENTRY_DSN=                                  # Sentry DSN for error tracking (backend)
VITE_SENTRY_DSN=                             # Sentry DSN for error tracking (frontend)

# --- PostHog (optional, frontend analytics) ---
VITE_POSTHOG_KEY=                            # PostHog project key (write-only). Leave blank to disable analytics.
VITE_POSTHOG_HOST=                           # PostHog API host. Defaults to https://us.i.posthog.com

# --- Testing ---
# REACT_APP_BACKEND_URL=http://localhost:8080  # Backend URL for integration tests
# TEST_PASSWORD=                                # Password for test user
