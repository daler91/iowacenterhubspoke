# ==============================================================================
# Iowa Center HubSpoke Scheduler - Environment Variables
# ==============================================================================
# Copy this file to backend/.env and fill in the values.
# Variables marked [REQUIRED] must be set. Others have sensible defaults.
# ==============================================================================

# --- Database ---
MONGO_URL=mongodb://localhost:27017          # [REQUIRED] MongoDB connection string
DB_NAME=iowa_center_hub                      # Database name (default: iowa_center_hub)

# --- Authentication ---
JWT_SECRET=change-me-to-a-random-secret      # [REQUIRED] Secret key for JWT token signing
ADMIN_EMAIL=                                 # Email to auto-promote to admin on startup (optional)

# --- Redis (used for background jobs & rate limiting) ---
REDIS_URL=redis://localhost:6379             # Redis connection string

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173  # Comma-separated allowed origins (default: *)

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=                         # Google Maps API key for drive time calculation & map view
VITE_GOOGLE_MAPS_API_KEY=                    # Same key, exposed to frontend via Vite

# --- Frontend ---
VITE_BACKEND_URL=                            # Backend API URL (leave empty if same-origin)

# --- Outlook Integration (optional) ---
AZURE_TENANT_ID=                             # Azure AD tenant ID for Outlook sync
AZURE_CLIENT_ID=                             # Azure AD app client ID
AZURE_CLIENT_SECRET=                         # Azure AD app client secret

# --- Google Calendar Integration (optional) ---
GOOGLE_SERVICE_ACCOUNT_FILE=                 # Path to Google service account JSON key file
GOOGLE_SA_CLIENT_EMAIL=                      # Alternative: service account email
GOOGLE_SA_PRIVATE_KEY=                       # Alternative: service account private key (PEM)
GOOGLE_SA_PROJECT_ID=                        # Alternative: GCP project ID

# --- Environment ---
ENVIRONMENT=development                      # Set to "production" for production deployments

# --- Sentry (optional) ---
SENTRY_DSN=                                  # Sentry DSN for error tracking (backend)
VITE_SENTRY_DSN=                             # Sentry DSN for error tracking (frontend)

# --- Testing ---
# REACT_APP_BACKEND_URL=http://localhost:8080  # Backend URL for integration tests
# TEST_PASSWORD=                                # Password for test user
